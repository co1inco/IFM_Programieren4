<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee" version="5.0">
  <!-- LayoutController for main routing -->
  <servlet>
    <servlet-name>LayoutController</servlet-name>
    <servlet-class>com.example.LayoutController</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LayoutController</servlet-name>
    <url-pattern>/</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>LayoutController</servlet-name>
    <url-pattern>/about</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>layoutcontroller</servlet-name>
    <url-pattern>/hello</url-pattern>
  </servlet-mapping>
</web-app>